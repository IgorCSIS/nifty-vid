# URL of the Cloudflare Worker that proxies to the HF Space.
# - In dev, point this at `wrangler dev` (default http://localhost:8787).
# - In production (GitHub Pages), set this as a repo variable named PUBLIC_WORKER_URL
#   under Settings -> Secrets and variables -> Actions -> Variables. The deploy
#   workflow picks it up at build time.
PUBLIC_WORKER_URL=http://localhost:8787
